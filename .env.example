# Environment variables for Twilio voice bot
# Copy this file to .env and fill in your actual credentials

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_account_sid_here
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o

# Application Configuration
FLASK_ENV=development
FLASK_DEBUG=False
PORT=5000

# Webhook Configuration (REQUIRED for production)
# For local development: http://localhost:5000
# For Render: https://your-app-name.onrender.com
BASE_URL=http://localhost:5000

# Test Number (the number the bot will call - REQUIRED)
TEST_PHONE_NUMBER=+18054398008

# Recording and Storage (relative paths are recommended for portability)
RECORDINGS_DIR=./recordings
TRANSCRIPT_DIR=./transcripts
